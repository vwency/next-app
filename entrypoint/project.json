{
  "name": "entrypoint",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "entrypoint/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "command": "next build && cp -r .next/static .next/standalone/entrypoint/.next/static && cp -r public .next/standalone/entrypoint/public",
        "cwd": "entrypoint"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next dev",
        "cwd": "entrypoint"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next start",
        "cwd": "entrypoint"
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "rm -rf .next dist",
        "cwd": "entrypoint"
      }
    }
  }
}
